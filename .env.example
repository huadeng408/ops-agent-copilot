APP_ENV=dev
APP_NAME=ops-agent-copilot
HOST=127.0.0.1
PORT=18000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=ops_agent
MYSQL_USER=root
MYSQL_PASSWORD=123456

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

LLM_PROVIDER=kimi
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=kimi-k2-0905-preview
# Optional: read LLM_API_KEY from auth.json in repo root or an absolute path.
# For local Ollama, prefer leaving this empty to avoid loading remote credentials.
LLM_AUTH_FILE=auth.json

# Local Ollama + Gemma4 profile example:
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_API_KEY=ollama-local
# LLM_MODEL=gemma4:e4b
# LLM_AUTH_FILE=

LOG_LEVEL=INFO
AGENT_RUNTIME_MODE=auto
LANGGRAPH_BASE_URL=http://127.0.0.1:8001
LANGGRAPH_TIMEOUT_MS=30000
LANGGRAPH_HOST=127.0.0.1
LANGGRAPH_PORT=8001
LANGGRAPH_MAX_STEP_REFLECTIONS=2
LANGGRAPH_MAX_ANSWER_REFLECTIONS=1
OPS_AGENT_BASE_URL=http://127.0.0.1:18000
INTERNAL_API_KEY=
METRICS_ENABLED=true
OTEL_ENABLED=true
OTEL_SERVICE_NAME=ops-agent-copilot
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

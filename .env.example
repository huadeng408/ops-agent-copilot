APP_ENV=dev
APP_NAME=ops-agent-copilot
HOST=0.0.0.0
PORT=8000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=ops_agent
MYSQL_USER=root
MYSQL_PASSWORD=123456

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=kimi-k2-0905-preview
OPENAI_TRUST_ENV=true
# Optional: read OPENAI_API_KEY from auth.json in repo root or an absolute path
OPENAI_AUTH_FILE=auth.json

LOG_LEVEL=INFO
AGENT_RUNTIME_MODE=auto
METRICS_ENABLED=true
OTEL_ENABLED=true
OTEL_SERVICE_NAME=ops-agent-copilot
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
